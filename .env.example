# Fiskr Environment Variables & Secrets Configuration

# Database Connection Settings
# Option A: Full Database Connection URL
# DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5438/fiskr

# Option B: Individual Database Parameters
DB_USER=postgres
DB_PASSWORD=postgrespassword
DB_HOST=localhost
DB_PORT=5438
DB_NAME=fiskr

# Authentication & JWT Security Settings
SECRET_KEY=fiskr_super_secret_jwt_key_change_in_production_2026
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword

# Envoi des rapports de synchronisation par email (optionnel)
# Laissez vide pour un suivi uniquement dans l'application.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=fiskr@example.com
# SMTP_PASSWORD=motdepasse_smtp
# SMTP_FROM=fiskr@example.com
# SYNC_EMAIL_TO=conformite@example.com,responsable-lcb@example.com
